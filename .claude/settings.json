{
  "$schema": "https://json-schema.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pytest*)",
      "Bash(python utils/generate_reports.py*)",
      "Bash(git status*)",
      "Bash(git diff*)"
    ],
    "ask": [
      "Bash(pip install*)",
      "Bash(playwright install*)",
      "Bash(git add*)",
      "Bash(git commit*)"
    ],
    "deny": [
      "Bash(git push*)"
    ]
  },
  "respectGitignore": true
}
